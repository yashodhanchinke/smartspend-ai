EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:3000

# For the AI Monthly Report Backend
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
# Optional: override Groq model (OpenAI-compatible)
GROQ_MODEL=llama-3.1-70b-versatile

# Email sending: Brevo SMTP (no OAuth)
# Create a Brevo account -> SMTP & API -> generate SMTP key (or API key for SMTP auth).
# Option A (simplest): use API key as SMTP password (username is "apikey")
BREVO_SMTP_KEY=your_brevo_api_key
# Option B: use Brevo-provided SMTP login/password
BREVO_SMTP_LOGIN=your_brevo_smtp_login
BREVO_SMTP_PASSWORD=your_brevo_smtp_password
EMAIL_FROM=SmartSpend AI <no-reply@yourdomain.com>
